{
  "id": "upper-glass-2door",
  "version": 1,
  "category": "upper-cabinet",
  "tags": [
    "glass",
    "frame",
    "2-door"
  ],
  "description": {
    "vi": "Tu tren 2 canh kinh",
    "en": "2-door glass upper cabinet"
  },
  "params": {
    "width": {
      "type": "number",
      "min": 40,
      "max": 200,
      "default": 95
    },
    "height": {
      "type": "number",
      "min": 50,
      "max": 130,
      "default": 90
    },
    "depth": {
      "type": "number",
      "min": 30,
      "max": 70,
      "default": 60
    }
  },
  "style": {
    "handle": {
      "values": [
        "bar",
        "knob"
      ],
      "default": "bar"
    }
  },
  "boxes": [
    {
      "x": 0,
      "y": 0,
      "z": 0,
      "w": "{{width}}",
      "h": "{{height}}",
      "d": "{{depth}}",
      "faces": {
        "top": "$woodTop",
        "front": "$woodFront",
        "right": "$woodSide",
        "left": "$woodDark",
        "back": "$woodBack"
      }
    },
    {
      "x": 4,
      "y": 12,
      "z": "{{depth - 6}}",
      "w": "{{width - 8}}",
      "h": 2,
      "d": "{{depth - 8}}",
      "faces": {
        "top": "$woodTop",
        "front": "$woodSide"
      }
    },
    {
      "x": 4,
      "y": "{{height / 2}}",
      "z": "{{depth - 6}}",
      "w": "{{width - 8}}",
      "h": 2,
      "d": "{{depth - 8}}",
      "faces": {
        "top": "$woodTop",
        "front": "$woodSide"
      }
    },
    {
      "x": 3,
      "y": 3,
      "z": "{{depth - 1}}",
      "w": "{{width / 2 - 4}}",
      "h": "{{height - 6}}",
      "d": 1,
      "faces": {
        "front": "$woodFrontL",
        "top": "$woodTop"
      }
    },
    {
      "x": "{{width / 2 + 1}}",
      "y": 3,
      "z": "{{depth - 1}}",
      "w": "{{width / 2 - 4}}",
      "h": "{{height - 6}}",
      "d": 1,
      "faces": {
        "front": "$woodFrontL",
        "top": "$woodTop"
      }
    },
    {
      "x": 6,
      "y": 8,
      "z": "{{depth - 0.4}}",
      "w": "{{width / 2 - 12}}",
      "h": "{{height - 16}}",
      "d": 0.4,
      "opacity": 0.62,
      "faces": {
        "front": "$glass"
      }
    },
    {
      "x": "{{width / 2 + 6}}",
      "y": 8,
      "z": "{{depth - 0.4}}",
      "w": "{{width / 2 - 12}}",
      "h": "{{height - 16}}",
      "d": 0.4,
      "opacity": 0.62,
      "faces": {
        "front": "$glass"
      }
    },
    {
      "x": "{{width / 2 - 5}}",
      "y": "{{height / 2 - 7}}",
      "z": "{{depth + 0.5}}",
      "w": 1.5,
      "h": 14,
      "d": 1.5,
      "faces": {
        "front": "$handle",
        "top": "$handleEdge",
        "right": "$handle",
        "left": "$handle"
      }
    },
    {
      "x": "{{width / 2 + 3.5}}",
      "y": "{{height / 2 - 7}}",
      "z": "{{depth + 0.5}}",
      "w": 1.5,
      "h": 14,
      "d": 1.5,
      "faces": {
        "front": "$handle",
        "top": "$handleEdge",
        "right": "$handle",
        "left": "$handle"
      }
    }
  ]
}
