{
  "id": "base-drawer-stack",
  "version": 1,
  "category": "drawer-base",
  "tags": [
    "kitchen",
    "base",
    "drawer"
  ],
  "description": {
    "vi": "Tu bep duoi ngan keo",
    "en": "Kitchen drawer base"
  },
  "params": {
    "width": {
      "type": "number",
      "min": 45,
      "max": 100,
      "default": 60
    },
    "height": {
      "type": "number",
      "min": 80,
      "max": 95,
      "default": 86
    },
    "depth": {
      "type": "number",
      "min": 55,
      "max": 65,
      "default": 60
    }
  },
  "style": {
    "drawers": {
      "values": [
        2,
        3,
        4
      ],
      "default": 3
    }
  },
  "boxes": [
    {
      "x": 0,
      "y": 8,
      "z": 0,
      "w": "{{width}}",
      "h": "{{height - 12}}",
      "d": "{{depth}}",
      "faces": {
        "top": "$woodTop",
        "front": "$woodFront",
        "right": "$woodSide",
        "left": "$woodDark",
        "back": "$woodBack"
      }
    },
    {
      "x": 0,
      "y": "{{height - 4}}",
      "z": 0,
      "w": "{{width}}",
      "h": 4,
      "d": "{{depth}}",
      "faces": {
        "top": "$stone",
        "front": "$stone",
        "right": "$stone",
        "left": "$stone"
      }
    },
    {
      "x": 3,
      "y": 0,
      "z": 3,
      "w": "{{width - 6}}",
      "h": 8,
      "d": "{{depth - 6}}",
      "faces": {
        "top": "$woodDark",
        "front": "$woodDark",
        "right": "$woodDark",
        "left": "$woodDark"
      }
    },
    {
      "x": 3,
      "y": 10,
      "z": "{{depth - 1}}",
      "w": "{{width - 6}}",
      "h": "{{(height - 20) / 3}}",
      "d": 1,
      "faces": {
        "front": "$woodFrontL",
        "top": "$woodTop",
        "right": "$woodSide",
        "left": "$woodDark"
      }
    },
    {
      "x": 3,
      "y": "{{10 + (height - 20) / 3}}",
      "z": "{{depth - 1}}",
      "w": "{{width - 6}}",
      "h": "{{(height - 20) / 3}}",
      "d": 1,
      "faces": {
        "front": "$woodFrontL",
        "top": "$woodTop",
        "right": "$woodSide",
        "left": "$woodDark"
      }
    },
    {
      "x": 3,
      "y": "{{10 + (height - 20) * 2 / 3}}",
      "z": "{{depth - 1}}",
      "w": "{{width - 6}}",
      "h": "{{(height - 20) / 3}}",
      "d": 1,
      "faces": {
        "front": "$woodFrontL",
        "top": "$woodTop",
        "right": "$woodSide",
        "left": "$woodDark"
      }
    },
    {
      "x": "{{width / 2 - 12}}",
      "y": "{{10 + (height - 20) / 6}}",
      "z": "{{depth + 0.3}}",
      "w": 24,
      "h": 1.5,
      "d": 1,
      "faces": {
        "front": "$handle",
        "top": "$handleEdge",
        "right": "$handle",
        "left": "$handle"
      }
    },
    {
      "x": "{{width / 2 - 12}}",
      "y": "{{10 + (height - 20) / 2}}",
      "z": "{{depth + 0.3}}",
      "w": 24,
      "h": 1.5,
      "d": 1,
      "faces": {
        "front": "$handle",
        "top": "$handleEdge",
        "right": "$handle",
        "left": "$handle"
      }
    },
    {
      "x": "{{width / 2 - 12}}",
      "y": "{{10 + (height - 20) * 5 / 6}}",
      "z": "{{depth + 0.3}}",
      "w": 24,
      "h": 1.5,
      "d": 1,
      "faces": {
        "front": "$handle",
        "top": "$handleEdge",
        "right": "$handle",
        "left": "$handle"
      }
    }
  ]
}
