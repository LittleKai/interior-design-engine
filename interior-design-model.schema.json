{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/interior-design-model.schema.json",
  "title": "Interior Design Engine Model",
  "type": "object",
  "additionalProperties": true,
  "required": ["width", "height", "depth"],
  "oneOf": [
    { "required": ["modules"] },
    { "required": ["runs"] }
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "units": {
      "type": "string",
      "default": "cm"
    },
    "width": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "height": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "depth": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "materials": {
      "type": "object",
      "description": "Shared material/color values used by legacy items and AI prompt/export helpers.",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "board": {
          "type": "string"
        }
      }
    },
    "palette": {
      "type": "string",
      "description": "Built-in renderer palette id. Unknown values are normalized to wood-oak by runtime validation.",
      "enum": ["wood-oak", "wood-walnut", "laminate-white", "dark-modern"]
    },
    "inlineTemplates": {
      "type": "object",
      "description": "Per-model boxes-based template definitions keyed by template id.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "params": {
            "type": "object",
            "additionalProperties": true
          },
          "boxes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/designItem"
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/run"
      }
    },
    "details": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/designItem"
      }
    },
    "specs": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 3,
        "items": {
          "type": "string"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "unsupportedRequests": {
          "type": "array",
          "description": "User requests the AI could not represent safely in the current model contract.",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "run": {
      "type": "object",
      "additionalProperties": true,
      "required": ["origin", "direction", "modules"],
      "properties": {
        "id": {
          "type": "string"
        },
        "origin": {
          "type": "object",
          "additionalProperties": true,
          "required": ["x", "z"],
          "properties": {
            "x": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "direction": {
          "type": "string",
          "enum": ["east", "north", "west", "south"]
        },
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/designItem"
          }
        }
      }
    },
    "designItem": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "description": "Render primitive or semantic body kind. `void` represents openings; other strings remain allowed for template/material semantics."
        },
        "catalogId": {
          "type": "string",
          "description": "Optional reference to a catalog element name registered via InteriorDesigner catalog registry."
        },
        "props": {
          "type": "object",
          "additionalProperties": true,
          "description": "Free-form properties consumed by the catalog element render2D/render3D handlers."
        },
        "group": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "depth": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "color": {
          "type": "string"
        },
        "materialRef": {
          "type": "string",
          "description": "Optional material preset reference, for example wood-oak or glass-smoked."
        },
        "tpl": {
          "type": "string",
          "description": "Optional boxes-based template id. The renderer resolves the template and projects boxes into all views."
        },
        "style": {
          "type": "object",
          "additionalProperties": true,
          "description": "Per-template style overrides consumed by the template interpreter."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "layer": {
          "type": "number"
        },
        "hiddenIn3d": {
          "type": "boolean"
        },
        "hideLabel": {
          "type": "boolean"
        }
      }
    }
  }
}
